# Copy to .env and fill in your values

# ── LLM / Embedding API Keys ──────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_INDEX_NAME=rag-docs

# ── RAG Backend (consumed by Next.js frontend) ────────────────────────────────
RAG_BACKEND_URL=http://localhost:8000
